[Unit]
Description=Stop idle browser editor (code-server)

[Service]
Type=oneshot
Environment=BROWSER_EDITOR_USER=__BROWSER_EDITOR_USER__
Environment=BROWSER_EDITOR_IDLE_SECONDS=3600
Environment=BROWSER_EDITOR_STAMP=/run/hb-browser-editor/last-request
ExecStart=/usr/local/lib/hb-browser-editor/idle-stop.sh
